{
  "name": "vitamind",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/website"
  ],
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "build:web": "cd apps/web && npm run build",
    "dev:website": "pnpm --filter @vitamind/website dev",
    "build:website": "pnpm --filter @vitamind/website build",
    "lint": "cd apps/web && npm run lint"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.42.0"
  }
}
